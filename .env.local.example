# ─── Supabase ──────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Google Maps ────────────────────────────────────────────────────────────
# Create an API key: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Create a Map ID: Google Cloud Console → Google Maps Platform → Map Management
# Required for AdvancedMarker (custom café pins on the map)
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your-map-id
